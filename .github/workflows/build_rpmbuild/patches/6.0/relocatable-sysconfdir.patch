 #include "debug.h"
 
+/* Relocatable SYSCONFDIR - resolves <prefix>/etc from /proc/self/exe */
+#include <unistd.h>
+static std::string _relocSysconfdir(const char *suffix = "") {
+    static std::string _prefix;
+    if (_prefix.empty()) {
+        char _exe[4096] = {};
+        ssize_t _len = readlink("/proc/self/exe", _exe, sizeof(_exe) - 1);
+        if (_len > 0) {
+            _exe[_len] = '\0';
+            char *_s = strrchr(_exe, '/');
+            if (_s) *_s = '\0';
+            _s = strrchr(_exe, '/');
+            if (_s) *_s = '\0';
+            _prefix = std::string(_exe) + "/etc";
+        } else {
+            _prefix = SYSCONFDIR;
+        }
+    }
+    return _prefix + suffix;
+}
