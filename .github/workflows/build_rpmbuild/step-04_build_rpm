#!/bin/bash
set -euox pipefail
source ${SCRIPTS_DIR}/environment

export PKG_CONFIG_PATH="${PREFIX}/lib/pkgconfig"

# ==============================
# || Apply source patches      ||
# ==============================

# Extract major.minor (e.g. "4.19" from "4.19.1.1", "4.20" from "4.20.1")
RPM_MAJOR_MINOR="$(echo "${RPM_VERSION}" | cut -d. -f1,2)"
PATCHES_DIR="${SCRIPTS_DIR}/patches/${RPM_MAJOR_MINOR}"

if [[ ! -d "${PATCHES_DIR}" ]]; then
    echo "ERROR: No patches found for RPM ${RPM_MAJOR_MINOR} at ${PATCHES_DIR}"
    exit 1
fi

for patch_file in "${PATCHES_DIR}"/*.patch; do
    echo "Applying $(basename "${patch_file}")..."
    patch -d "${RPM_SOURCE}" -p1 < "${patch_file}"
done

# ==============================
# || Configure and build RPM  ||
# ==============================

RPM_BUILD="/tmp/rpm-build"
mkdir -p ${RPM_BUILD}

# Version-specific CMake flags
#
# RPM < 4.20: Uses WITH_INTERNAL_OPENPGP for crypto (no Sequoia dependency).
#             Has WITH_ARCHIVE option (libarchive support in rpm2archive).
# RPM >= 4.20: Uses WITH_SEQUOIA for crypto. Dropped WITH_INTERNAL_OPENPGP.
#              Dropped WITH_ARCHIVE option. Added WITH_ICONV, WITH_LIBDW,
#              WITH_LIBELF, WITH_DOXYGEN as explicit options.
VERSION_FLAGS=()
case "${RPM_MAJOR_MINOR}" in
    4.19)
        VERSION_FLAGS+=(
            -DWITH_INTERNAL_OPENPGP=ON
            -DWITH_ARCHIVE=OFF
        )
        ;;
    *)
        VERSION_FLAGS+=(
            -DWITH_SEQUOIA=OFF
            -DWITH_ICONV=OFF
            -DWITH_LIBDW=OFF
            -DWITH_LIBELF=OFF
            -DWITH_DOXYGEN=OFF
        )
        ;;
esac

cmake -S ${RPM_SOURCE} -B ${RPM_BUILD} \
    -DCMAKE_INSTALL_PREFIX="${PREFIX}" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_POSITION_INDEPENDENT_CODE=ON \
    -DCMAKE_FIND_LIBRARY_SUFFIXES=".a" \
    -DCMAKE_LIBRARY_PATH="${PREFIX}/lib" \
    -DCMAKE_PREFIX_PATH="${PREFIX}" \
    -DENABLE_PYTHON=OFF \
    -DENABLE_PLUGINS=OFF \
    -DENABLE_TESTSUITE=OFF \
    -DENABLE_NLS=ON \
    -DENABLE_OPENMP=OFF \
    -DENABLE_SQLITE=ON \
    -DENABLE_NDB=ON \
    -DWITH_CAP=OFF \
    -DWITH_ACL=OFF \
    -DWITH_SELINUX=OFF \
    -DWITH_DBUS=OFF \
    -DWITH_AUDIT=OFF \
    -DWITH_FAPOLICYD=OFF \
    -DWITH_IMAEVM=OFF \
    -DWITH_FSVERITY=OFF \
    -DWITH_READLINE=OFF \
    -DWITH_OPENSSL=ON \
    -DWITH_BZIP2=ON \
    -DWITH_ZSTD=ON \
    -DWITH_LIBLZMA=ON \
    -DZLIB_LIBRARY="${PREFIX}/lib/libz.a" \
    -DZLIB_INCLUDE_DIR="${PREFIX}/include" \
    -DBZIP2_LIBRARY_RELEASE="${PREFIX}/lib/libbz2.a" \
    -DBZIP2_INCLUDE_DIR="${PREFIX}/include" \
    -DMAGIC_LIBRARY="${PREFIX}/lib/libmagic.a" \
    -DLUA_LIBRARIES:FILEPATH="${PREFIX}/lib/liblua.a;m" \
    -DLUA_INCLUDE_DIR:PATH="${PREFIX}/include" \
    "${VERSION_FLAGS[@]}"

cmake --build ${RPM_BUILD} --target rpmbuild -j$(nproc)
